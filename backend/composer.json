{
    "name": "tienda/ecommerce",
    "description": "Sistema de gestión de pedidos y e-commerce",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "vlucas/phpdotenv": "^5.5",
        "phpmailer/phpmailer": "^6.8",
        "firebase/php-jwt": "^6.8",
        "jasongrimes/paginator": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "Config\\": "config/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}