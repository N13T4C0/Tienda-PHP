{
    "name": "alumno/tiendaphp",
    "description": "Proyecto Tienda PHP para 2DAW (basado en pablovacasgarcia/TiendaPHP, adaptado).",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Controladores\\": "src/Controladores/",
            "Servicios\\":     "src/Servicios/",
            "Repositorios\\":  "src/Repositorios/",
            "Lib\\":           "src/Lib/",
            "Middleware\\":    "src/Middleware/",
            "Requests\\":      "src/Requests/",
            "Rutas\\":         "src/Rutas/",
            "Utils\\":         "src/Utils/",
            "Config\\":        "config/",
            "Modelos\\":       "src/Modelos/"
        }
    },
    "minimum-stability": "stable",
    "require": {
        "phpmailer/phpmailer": "^7.0",
        "paypal/paypal-server-sdk": "^2.2"
    }
}
