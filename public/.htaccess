# Activar mod_rewrite
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /ProyectoTiendaPHP/Tienda-PHP/public/

    # Si existe el archivo o carpeta, servirlo directamente
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Si no, enviar todo a index.php
    RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]
</IfModule>